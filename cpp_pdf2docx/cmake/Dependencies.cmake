function(_pdf2docx_detect_path var_name)
  foreach(candidate IN LISTS ARGN)
    if(EXISTS "${candidate}/CMakeLists.txt")
      set(${var_name} "${candidate}" PARENT_SCOPE)
      return()
    endif()
  endforeach()
  set(${var_name} "" PARENT_SCOPE)
endfunction()

function(_pdf2docx_log_path dep_name dep_path)
  if(dep_path)
    message(STATUS "[deps] ${dep_name}: found at ${dep_path}")
  else()
    message(WARNING "[deps] ${dep_name}: source path not found")
  endif()
endfunction()

function(_pdf2docx_target_version out_var target_name)
  set(version "unknown")
  if(target_name AND TARGET ${target_name})
    get_target_property(target_version ${target_name} VERSION)
    if(target_version AND NOT target_version STREQUAL "target_version-NOTFOUND")
      set(version "${target_version}")
    endif()
  endif()
  set(${out_var} "${version}" PARENT_SCOPE)
endfunction()

function(_pdf2docx_log_dependency dep_name dep_path dep_target dep_version dep_enabled)
  if(dep_enabled)
    if(dep_path)
      set(dep_source "${dep_path}")
    else()
      set(dep_source "<system>")
    endif()
    if(NOT dep_target)
      set(dep_target "<none>")
    endif()
    if(NOT dep_version)
      set(dep_version "unknown")
    endif()
    message(STATUS "[deps] ${dep_name}: source=${dep_source}, target=${dep_target}, version=${dep_version}")
  else()
    message(WARNING "[deps] ${dep_name}: unresolved")
  endif()
endfunction()

function(_pdf2docx_try_link_target out_var)
  foreach(candidate IN LISTS ARGN)
    if(TARGET ${candidate})
      set(${out_var} "${candidate}" PARENT_SCOPE)
      return()
    endif()
  endforeach()
  set(${out_var} "" PARENT_SCOPE)
endfunction()

function(_pdf2docx_import_zlib zlib_path use_bundled add_subdir)
  set(PDF2DOCX_ZLIB_VERSION "unknown")
  find_package(ZLIB QUIET)
  if(use_bundled AND add_subdir AND zlib_path AND NOT TARGET ZLIB::ZLIB AND NOT TARGET zlib)
    add_subdirectory("${zlib_path}" "${CMAKE_BINARY_DIR}/_deps/zlib" EXCLUDE_FROM_ALL)
  endif()

  _pdf2docx_try_link_target(PDF2DOCX_ZLIB_TARGET ZLIB::ZLIB zlib zlibstatic)
  if(ZLIB_VERSION_STRING)
    set(PDF2DOCX_ZLIB_VERSION "${ZLIB_VERSION_STRING}")
  endif()
  if(PDF2DOCX_ZLIB_TARGET)
    _pdf2docx_target_version(_zlib_target_version "${PDF2DOCX_ZLIB_TARGET}")
    if(NOT _zlib_target_version STREQUAL "unknown")
      set(PDF2DOCX_ZLIB_VERSION "${_zlib_target_version}")
    endif()
    set(PDF2DOCX_HAS_ZLIB 1 PARENT_SCOPE)
    set(PDF2DOCX_ZLIB_TARGET "${PDF2DOCX_ZLIB_TARGET}" PARENT_SCOPE)
  else()
    set(PDF2DOCX_HAS_ZLIB 0 PARENT_SCOPE)
    set(PDF2DOCX_ZLIB_TARGET "" PARENT_SCOPE)
  endif()
  set(PDF2DOCX_ZLIB_VERSION "${PDF2DOCX_ZLIB_VERSION}" PARENT_SCOPE)
endfunction()

