    _pdf2docx_target_version(_minizip_target_version "${PDF2DOCX_MINIZIP_TARGET}")
    if(NOT _minizip_target_version STREQUAL "unknown")
      set(PDF2DOCX_MINIZIP_VERSION "${_minizip_target_version}")
    endif()
    set(PDF2DOCX_HAS_MINIZIP 1 PARENT_SCOPE)
    set(PDF2DOCX_MINIZIP_TARGET "${PDF2DOCX_MINIZIP_TARGET}" PARENT_SCOPE)
  else()
    set(PDF2DOCX_HAS_MINIZIP 0 PARENT_SCOPE)
    set(PDF2DOCX_MINIZIP_TARGET "" PARENT_SCOPE)
  endif()
  set(PDF2DOCX_MINIZIP_VERSION "${PDF2DOCX_MINIZIP_VERSION}" PARENT_SCOPE)
endfunction()

