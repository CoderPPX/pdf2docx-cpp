  _pdf2docx_try_link_target(PDF2DOCX_PODOFO_TARGET podofo::podofo podofo_shared podofo_static)
  if(PDF2DOCX_PODOFO_TARGET)
    _pdf2docx_target_version(_podofo_target_version "${PDF2DOCX_PODOFO_TARGET}")
