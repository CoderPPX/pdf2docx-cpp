  endif()
  set(PDF2DOCX_PODOFO_VERSION "${PDF2DOCX_PODOFO_VERSION}" PARENT_SCOPE)
endfunction()

function(pdf2docx_import_dependencies thirdparty_root use_bundled add_subdir strict_deps)
  _pdf2docx_detect_path(PDF2DOCX_PATH_ZLIB
    "${thirdparty_root}/zlib")
  _pdf2docx_detect_path(PDF2DOCX_PATH_TINYXML2
    "${thirdparty_root}/tinyxml2")
  _pdf2docx_detect_path(PDF2DOCX_PATH_MINIZIP
    "${thirdparty_root}/minizip-ng")
  _pdf2docx_detect_path(PDF2DOCX_PATH_FREETYPE
    "${thirdparty_root}/freetype2"
    "${thirdparty_root}/freetype")
  _pdf2docx_detect_path(PDF2DOCX_PATH_PODOFO
    "${thirdparty_root}/podofo")

  _pdf2docx_log_path(zlib "${PDF2DOCX_PATH_ZLIB}")
  _pdf2docx_log_path(tinyxml2 "${PDF2DOCX_PATH_TINYXML2}")
  _pdf2docx_log_path(minizip-ng "${PDF2DOCX_PATH_MINIZIP}")
  _pdf2docx_log_path(freetype2 "${PDF2DOCX_PATH_FREETYPE}")
  _pdf2docx_log_path(podofo "${PDF2DOCX_PATH_PODOFO}")

  _pdf2docx_import_zlib("${PDF2DOCX_PATH_ZLIB}" ${use_bundled} ${add_subdir})
  _pdf2docx_import_tinyxml2("${PDF2DOCX_PATH_TINYXML2}" ${use_bundled} ${add_subdir})
  _pdf2docx_import_minizip("${PDF2DOCX_PATH_MINIZIP}" ${use_bundled} ${add_subdir})
  _pdf2docx_import_freetype("${PDF2DOCX_PATH_FREETYPE}" ${use_bundled} ${add_subdir})
  _pdf2docx_import_podofo("${PDF2DOCX_PATH_PODOFO}" ${use_bundled} ${add_subdir})

  set(PDF2DOCX_HAS_ZLIB ${PDF2DOCX_HAS_ZLIB} PARENT_SCOPE)
  set(PDF2DOCX_HAS_TINYXML2 ${PDF2DOCX_HAS_TINYXML2} PARENT_SCOPE)
  set(PDF2DOCX_HAS_MINIZIP ${PDF2DOCX_HAS_MINIZIP} PARENT_SCOPE)
  set(PDF2DOCX_HAS_FREETYPE ${PDF2DOCX_HAS_FREETYPE} PARENT_SCOPE)
  set(PDF2DOCX_HAS_PODOFO ${PDF2DOCX_HAS_PODOFO} PARENT_SCOPE)

  set(PDF2DOCX_ZLIB_TARGET "${PDF2DOCX_ZLIB_TARGET}" PARENT_SCOPE)
  set(PDF2DOCX_TINYXML2_TARGET "${PDF2DOCX_TINYXML2_TARGET}" PARENT_SCOPE)
  set(PDF2DOCX_MINIZIP_TARGET "${PDF2DOCX_MINIZIP_TARGET}" PARENT_SCOPE)
  set(PDF2DOCX_FREETYPE_TARGET "${PDF2DOCX_FREETYPE_TARGET}" PARENT_SCOPE)
  set(PDF2DOCX_PODOFO_TARGET "${PDF2DOCX_PODOFO_TARGET}" PARENT_SCOPE)

  set(PDF2DOCX_ZLIB_VERSION "${PDF2DOCX_ZLIB_VERSION}" PARENT_SCOPE)
  set(PDF2DOCX_TINYXML2_VERSION "${PDF2DOCX_TINYXML2_VERSION}" PARENT_SCOPE)
  set(PDF2DOCX_MINIZIP_VERSION "${PDF2DOCX_MINIZIP_VERSION}" PARENT_SCOPE)
  set(PDF2DOCX_FREETYPE_VERSION "${PDF2DOCX_FREETYPE_VERSION}" PARENT_SCOPE)
  set(PDF2DOCX_PODOFO_VERSION "${PDF2DOCX_PODOFO_VERSION}" PARENT_SCOPE)

  _pdf2docx_log_dependency("zlib" "${PDF2DOCX_PATH_ZLIB}" "${PDF2DOCX_ZLIB_TARGET}" "${PDF2DOCX_ZLIB_VERSION}" ${PDF2DOCX_HAS_ZLIB})
  _pdf2docx_log_dependency("tinyxml2" "${PDF2DOCX_PATH_TINYXML2}" "${PDF2DOCX_TINYXML2_TARGET}" "${PDF2DOCX_TINYXML2_VERSION}" ${PDF2DOCX_HAS_TINYXML2})
  _pdf2docx_log_dependency("minizip-ng" "${PDF2DOCX_PATH_MINIZIP}" "${PDF2DOCX_MINIZIP_TARGET}" "${PDF2DOCX_MINIZIP_VERSION}" ${PDF2DOCX_HAS_MINIZIP})
  _pdf2docx_log_dependency("freetype2" "${PDF2DOCX_PATH_FREETYPE}" "${PDF2DOCX_FREETYPE_TARGET}" "${PDF2DOCX_FREETYPE_VERSION}" ${PDF2DOCX_HAS_FREETYPE})
  _pdf2docx_log_dependency("podofo" "${PDF2DOCX_PATH_PODOFO}" "${PDF2DOCX_PODOFO_TARGET}" "${PDF2DOCX_PODOFO_VERSION}" ${PDF2DOCX_HAS_PODOFO})

  if(strict_deps)
    set(_missing_deps "")
    if(NOT PDF2DOCX_HAS_ZLIB)
      list(APPEND _missing_deps "zlib")
    endif()
    if(NOT PDF2DOCX_HAS_TINYXML2)
      list(APPEND _missing_deps "tinyxml2")
    endif()
    if(NOT PDF2DOCX_HAS_MINIZIP)
      list(APPEND _missing_deps "minizip-ng")
    endif()
    if(NOT PDF2DOCX_HAS_FREETYPE)
      list(APPEND _missing_deps "freetype2")
    endif()
    if(NOT PDF2DOCX_HAS_PODOFO)
      list(APPEND _missing_deps "podofo")
    endif()
    if(_missing_deps)
      string(REPLACE ";" ", " _missing_deps_csv "${_missing_deps}")
      message(FATAL_ERROR "[deps] strict mode enabled, missing: ${_missing_deps_csv}")
    endif()
  endif()

  message(STATUS "[deps] resolved: zlib=${PDF2DOCX_HAS_ZLIB}, tinyxml2=${PDF2DOCX_HAS_TINYXML2}, minizip=${PDF2DOCX_HAS_MINIZIP}, freetype=${PDF2DOCX_HAS_FREETYPE}, podofo=${PDF2DOCX_HAS_PODOFO}, strict=${strict_deps}")
endfunction()
